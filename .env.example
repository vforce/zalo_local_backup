# Copy this file to .env and fill in your own values:
#   cp .env.example .env

# Your Zalo account's numeric media folder. Find it with:
#   ls ~/Library/Application\ Support/ZaloData/media/
ZALO_ACCOUNT_ID=

# SSH target for your backup server. Must be key-based (no password prompt).
# Set it up once with: ssh-copy-id user@host
HOST=user@host

# Two destination folders on that server (uploaded once, then mirrored remote-side).
DEST1=/path/on/server/zalo_backup
DEST2=/other/path/on/server/zalo_backup

# Optional: parallel JPEG-XL decode workers (default 6). Roughly your CPU core count.
JOBS=6
